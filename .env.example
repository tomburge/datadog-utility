# Application Settings (Optional)
LOG_LEVEL=INFO

# DataDog API Credentials (Required)
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_app_key_here
DD_ACCOUNT_ID=

# DataDog Configuration (Optional)
DD_SITE=datadoghq.com
DD_PARTITION=aws
DATADOG_VERIFY_SSL=false

# AWS Configuration (Required)
AWS_ACCOUNT_ID=123456789012
AWS_PROFILE=default

# AWS IAM Configuration (Optional)
DD_IAM_ROLE_NAME=datadog-integration-role

# AWS IAM Role Tags (Optional, comma-separated Key=Value pairs, 1-50 tags)
DD_IAM_TAGS=ApplicationName=datadog,Environment=sandbox,CostCenter=platform,ManagedBy=ddutil

# AWS Managed Policies (Optional, comma-separated ARNs)
# Defaults: arn:aws:iam::aws:policy/ReadOnlyAccess,arn:aws:iam::aws:policy/SecurityAudit
DD_MANAGED_POLICIES=

# Additional IAM Policy Actions (Optional, comma-separated)
# Defaults: (32 actions - see cli.py for full list)
DD_POLICY_ACTIONS=

# DataDog Monitoring Configuration (Optional)
# Regions: Comma-separated list of AWS regions to monitor (empty = all regions)
DD_REGIONS=

# DataDog Metric Settings (Optional, true/false)
DD_METRIC_AUTOMUTE=true
DD_METRIC_COLLECT_CLOUDWATCH=true
DD_METRIC_COLLECT_CUSTOM=false
DD_METRIC_COLLECT_METRICS=true
DD_METRIC_ENABLE=true

# DataDog Resource Settings (Optional, true/false)
DD_RESOURCE_COLLECT_CSPM=false
DD_RESOURCE_COLLECT_EXTENDED=true

# Services: Individual service toggles (true/false)
# Use DD_SERVICES=svc1,svc2 to override all toggles with a comma-separated list
# AI & ML
DD_SERVICE_BEDROCK=false
DD_SERVICE_ELASTIC_INFERENCE=false
DD_SERVICE_LEX=false
DD_SERVICE_ML=false
DD_SERVICE_POLLY=false
DD_SERVICE_REKOGNITION=false
DD_SERVICE_SAGEMAKER=false
DD_SERVICE_SAGEMAKER_ENDPOINTS=false
DD_SERVICE_SAGEMAKER_LABELING_JOBS=false
DD_SERVICE_SAGEMAKER_MODEL_BUILDING_PIPELINE=false
DD_SERVICE_SAGEMAKER_PROCESSING_JOBS=false
DD_SERVICE_SAGEMAKER_TRAINING_JOBS=false
DD_SERVICE_SAGEMAKER_TRANSFORM_JOBS=false
DD_SERVICE_SAGEMAKER_WORKTEAM=false
DD_SERVICE_TEXTRACT=false
DD_SERVICE_TRANSLATE=false

# Analytics & Big Data
DD_SERVICE_ATHENA=true
DD_SERVICE_ELASTIC_MAPREDUCE=false
DD_SERVICE_GLUE=true
DD_SERVICE_PCS=false

# API & App Integration
DD_SERVICE_AMAZON_MQ=false
DD_SERVICE_AMAZON_MWAA=false
DD_SERVICE_API_GATEWAY=true
DD_SERVICE_APP_SYNC=true
DD_SERVICE_KAFKA=true
DD_SERVICE_KINESIS=true
DD_SERVICE_KINESIS_ANALYTICS=true
DD_SERVICE_SNS=true
DD_SERVICE_SQS=true

# Compute
DD_SERVICE_AUTO_SCALING=true
DD_SERVICE_EC2=true
DD_SERVICE_EC2_API=true
DD_SERVICE_EC2_INFRASTRUCTURE_PERFORMANCE=true
DD_SERVICE_EC2_SPOT=true
DD_SERVICE_ELASTIC_BEANSTALK=false

# Containers
DD_SERVICE_APP_RUNNER=false
DD_SERVICE_ECR=false
DD_SERVICE_ECS=true

# Billing & Cost Management
DD_SERVICE_BILLING=true
DD_SERVICE_BUDGETING=true

# Communication & Collaboration
DD_SERVICE_CONNECT=false
DD_SERVICE_SES=false

# Databases
DD_SERVICE_CASSANDRA=true
DD_SERVICE_DAX=true
DD_SERVICE_DMS=false
DD_SERVICE_DOCDB=false
DD_SERVICE_DYNAMODB=true
DD_SERVICE_ELASTICACHE=true
DD_SERVICE_MEMORYDB=false
DD_SERVICE_NEPTUNE=false
DD_SERVICE_RDS=true
DD_SERVICE_RDS_PROXY=true
DD_SERVICE_REDSHIFT=false

# Developer Tools
DD_SERVICE_CODEBUILD=false
DD_SERVICE_CODEWHISPERER=false

# End User Computing
DD_SERVICE_APP_STREAM=false
DD_SERVICE_WORKSPACES=false

# Event & Integration Services
DD_SERVICE_EVENTBRIDGE_PIPES=true
DD_SERVICE_EVENTS=true
DD_SERVICE_FIREHOSE=true

# Game & Global Services
DD_SERVICE_GAMELIFT=false
DD_SERVICE_GLOBAL_ACCELERATOR=false

# IoT
DD_SERVICE_IOT=false

# Load Balancing
DD_SERVICE_APPLICATION_ELB=true
DD_SERVICE_ELB=true
DD_SERVICE_NETWORK_ELB=true

# Logging & Observability
DD_SERVICE_LOGS=true
DD_SERVICE_X_RAY=true

# Management
DD_SERVICE_BACKUP=false
DD_SERVICE_CONFIG=false
DD_SERVICE_SERVICE_QUOTAS=true
DD_SERVICE_TRUSTED_ADVISOR=true
DD_SERVICE_USAGE=true

# Media Services
DD_SERVICE_ELASTIC_TRANSCODER=false
DD_SERVICE_MEDIA_CONNECT=false
DD_SERVICE_MEDIA_CONVERT=false
DD_SERVICE_MEDIA_LIVE=false
DD_SERVICE_MEDIA_PACKAGE=false
DD_SERVICE_MEDIA_STORE=false
DD_SERVICE_MEDIA_TAILOR=false

# Networking & Content Delivery
DD_SERVICE_CLOUDFRONT=true
DD_SERVICE_DX=false
DD_SERVICE_NAT_GATEWAY=false
DD_SERVICE_NETWORK_FIREWALL=false
DD_SERVICE_NETWORK_MANAGER=false
DD_SERVICE_NETWORK_MONITOR=false
DD_SERVICE_ROUTE53=false
DD_SERVICE_ROUTE53_RESOLVER=false
DD_SERVICE_TRANSIT_GATEWAY=false
DD_SERVICE_VPN=false

# Private Link
DD_SERVICE_PRIVATELINK_ENDPOINTS=false
DD_SERVICE_PRIVATELINK_SERVICES=false

# Search
DD_SERVICE_AOSS=false
DD_SERVICE_CLOUDSEARCH=false
DD_SERVICE_OPENSEARCH=false

# Security and Identity
DD_SERVICE_CERTIFICATE_MANAGER=true
DD_SERVICE_CLOUDHSM=false
DD_SERVICE_COGNITO=false
DD_SERVICE_DDOS_PROTECTION=true
DD_SERVICE_INSPECTOR=false
DD_SERVICE_KMS=true
DD_SERVICE_WAF=false
DD_SERVICE_WAFV2=true

# Serverless
DD_SERVICE_LAMBDA=true
DD_SERVICE_SCHEDULER=true
DD_SERVICE_STATES=true
DD_SERVICE_SWF=false

# Storage
DD_SERVICE_EBS=true
DD_SERVICE_EFS=true
DD_SERVICE_FSX=false
DD_SERVICE_S3=true
DD_SERVICE_S3_STORAGE_LENS=true
DD_SERVICE_STORAGE_GATEWAY=false

# Traces: Individual service toggles for X-Ray tracing (true/false)
# Use DD_TRACES=svc1,svc2 to override all toggles with a comma-separated list
DD_TRACE_APP_SYNC=false
DD_TRACE_LAMBDA=false

